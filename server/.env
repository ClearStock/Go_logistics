# Servidor
PORT=8787

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/gologistics?schema=public

# Sessão (cookie assinado + tabela `session` via connect-pg-simple)
# Em produção use um valor longo e aleatório.
SESSION_SECRET=

# Encriptação em repouso (AES-256-GCM): 64 caracteres hex OU qualquer string (derivada com SHA-256).
# Em desenvolvimento, se omitir, é usada uma chave insegura por defeito (nunca em produção).
FIELD_ENCRYPTION_KEY=

# CORS (origens do front-end, separadas por vírgula; omitir = localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# Após OAuth bem-sucedido (redirecionar o browser)
APICBASE_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/?apicbase_oauth=ok

# redirect_uri por omissão na API de integração (deve coincidir com o registado na Apicbase)
DEFAULT_OAUTH_REDIRECT_URI=http://localhost:8787/api/auth/apicbase/callback

# Opcional: URLs Apicbase
# APICBASE_TOKEN_URL=https://api.apicbase.com/oauth/token/
# APICBASE_API_BASE_URL=https://api.apicbase.com
# APICBASE_VALIDATE_PATH=/api/v2/accounts/users
